{
  "name": "splat-web-viewer",
  "version": "0.1.0",
  "description": "Anti-aliased WebGPU Gaussian splat viewer with SPZ streaming and WebRTC",
  "type": "module",
  "scripts": {
    "build": "tsc && rollup -c",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ benchmarks/ examples/ --ext .ts",
    "docs": "typedoc",
    "benchmark": "tsx benchmarks/performance_test.ts",
    "demo": "python -m http.server 8080",
    "stream-demo": "concurrently \"python src/streaming/webrtc_server.py\" \"npm run demo\""
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.0",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@webgpu/types": "^0.1.64",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.0",
    "rollup": "^4.13.0",
    "tslib": "^2.6.0",
    "tsx": "^4.7.1",
    "typedoc": "^0.26.3",
    "typescript": "^5.4.0",
    "vitest": "^2.1.8"
  }
}
